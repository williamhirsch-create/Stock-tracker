<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Daily Stock Picks — Educational Demo</title>
    <!-- Tailwind Play CDN (for quick, single-file deploys) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React 18 from CDN -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  </head>
  <body class="bg-gradient-to-b from-slate-50 to-white text-slate-800">
    <div id="root"></div>

    <script>
      const { useEffect, useMemo, useState } = React;

      // ---------- Utils ----------
      const fmt = new Intl.NumberFormat('en-US', { maximumFractionDigits: 2 });
      const pct = (x) => (x * 100).toFixed(2) + '%';

      function calculateSMA(values, period) {
        const out = [];
        let sum = 0;
        for (let i = 0; i < values.length; i++) {
          sum += values[i];
          if (i >= period) sum -= values[i - period];
          out.push(i >= period - 1 ? sum / period : null);
        }
        return out;
      }

      // EMA helper for MACD
      function calculateEMA(values, period) {
        const out = Array(values.length).fill(null);
        const k = 2 / (period + 1);
        let ema = null;
        for (let i = 0; i < values.length; i++) {
          const v = values[i];
          if (v == null) continue;
          if (ema == null) {
            // seed EMA with SMA of first period
            if (i >= period - 1) {
              let sum = 0;
              for (let j = i - period + 1; j <= i; j++) sum += values[j];
              ema = sum / period;
              out[i] = ema;
            }
          } else {
            ema = v * k + ema * (1 - k);
            out[i] = ema;
          }
        }
        return out;
      }

      function calculateMACD(closes, fast = 12, slow = 26, signal = 9) {
        const emaFast = calculateEMA(closes, fast);
        const emaSlow = calculateEMA(closes, slow);
        const macd = closes.map((_, i) => (emaFast[i] != null && emaSlow[i] != null ? emaFast[i] - emaSlow[i] : null));
        const signalLine = calculateEMA(macd.map(x => (x == null ? 0 : x)), signal);
        const hist = macd.map((m, i) => (m != null && signalLine[i] != null ? m - signalLine[i] : null));
        return { macd, signal: signalLine, hist };
      }

      function calculateRSI(closes, period = 14) {
        if (closes.length < period + 1) return Array(closes.length).fill(null);
        const deltas = closes.map((c, i) => (i === 0 ? 0 : c - closes[i - 1]));
        let gains = 0, losses = 0;
        for (let i = 1; i <= period; i++) {
          const d = deltas[i];
          if (d >= 0) gains += d; else losses -= d;
        }
        let avgGain = gains / period;
        let avgLoss = losses / period;
        const rsi = Array(closes.length).fill(null);
        let rs = avgLoss === 0 ? 100 : avgGain / avgLoss;
        rsi[period] = 100 - 100 / (1 + rs);
        for (let i = period + 1; i < closes.length; i++) {
          const d = deltas[i];
          const gain = d > 0 ? d : 0;
          const loss = d < 0 ? -d : 0;
          avgGain = (avgGain * (period - 1) + gain) / period;
          avgLoss = (avgLoss * (period - 1) + loss) / period;
          rs = avgLoss === 0 ? 100 : avgGain / avgLoss;
          rsi[i] = 100 - 100 / (1 + rs);
        }
        return rsi;
      }

      const sleep = (ms) => new Promise((res) => setTimeout(res, ms));
      const todayISO = () => new Date(Date.now() - new Date().getTimezoneOffset() * 60000).toISOString().slice(0, 10);

      // ---------- Mock series for demo mode ----------
      const MOCK_SERIES = {
        AAPL: { 'Time Series (Daily)': Object.fromEntries(Array.from({ length: 200 }).map((_, idx) => { const d = new Date(); d.setDate(d.getDate() - idx); const date = d.toISOString().slice(0,10); const base = 220 + Math.sin(idx/7)*10 + idx*0.05; return [date, { '4. close': (base + Math.random()*1).toFixed(2) }]; })) },
        MSFT: { 'Time Series (Daily)': Object.fromEntries(Array.from({ length: 200 }).map((_, idx) => { const d = new Date(); d.setDate(d.getDate() - idx); const date = d.toISOString().slice(0,10); const base = 430 + Math.cos(idx/9)*8 - idx*0.03; return [date, { '4. close': (base + Math.random()*1).toFixed(2) }]; })) },
        NVDA: { 'Time Series (Daily)': Object.fromEntries(Array.from({ length: 200 }).map((_, idx) => { const d = new Date(); d.setDate(d.getDate() - idx); const date = d.toISOString().slice(0,10); const base = 124 + Math.sin(idx/4)*14; return [date, { '4. close': (base + Math.random()*2).toFixed(2) }]; })) },
        GOOGL:{ 'Time Series (Daily)': Object.fromEntries(Array.from({ length: 200 }).map((_, idx) => { const d = new Date(); d.setDate(d.getDate() - idx); const date = d.toISOString().slice(0,10); const base = 170 + Math.cos(idx/6)*5 + idx*0.02; return [date, { '4. close': (base + Math.random()*0.6).toFixed(2) }]; })) },
        AMZN: { 'Time Series (Daily)': Object.fromEntries(Array.from({ length: 200 }).map((_, idx) => { const d = new Date(); d.setDate(d.getDate() - idx); const date = d.toISOString().slice(0,10); const base = 183 + Math.sin(idx/10)*4 + idx*0.04; return [date, { '4. close': (base + Math.random()*0.5).toFixed(2) }]; })) },
      };

      function App() {
        const [apiKey, setApiKey] = useState(localStorage.getItem('av_key') || '');
        const [tickers, setTickers] = useState(localStorage.getItem('tickers') || 'AAPL,MSFT,NVDA,GOOGL,AMZN');
        const [batchSize, setBatchSize] = useState(Number(localStorage.getItem('batch') || 5));
        const [status, setStatus] = useState('');
        const [results, setResults] = useState([]);
        const [isLoading, setIsLoading] = useState(false);
        const [useMock, setUseMock] = useState(!localStorage.getItem('av_key'));
        const [today, setToday] = useState(todayISO());

        useEffect(() => { localStorage.setItem('av_key', apiKey); setUseMock(!apiKey); }, [apiKey]);
        useEffect(() => { localStorage.setItem('tickers', tickers); }, [tickers]);
        useEffect(() => { localStorage.setItem('batch', String(batchSize)); }, [batchSize]);

        async function fetchSeries(symbol) {
          if (useMock) { await sleep(80); return MOCK_SERIES[symbol]?.['Time Series (Daily)'] || null; }
          const cacheKey = `av_${symbol}`;
          const cached = localStorage.getItem(cacheKey);
          if (cached) {
            try {
              const { ts, data } = JSON.parse(cached);
              if (ts && ts.slice(0,10) === todayISO().slice(0,10)) return data;
            } catch {}
          }
          const url = `https://www.alphavantage.co/query?function=TIME_SERIES_DAILY_ADJUSTED&symbol=${symbol}&apikey=${apiKey}`;
          const resp = await fetch(url);
          const json = await resp.json();
          const series = json['Time Series (Daily)'];
          if (!series) throw new Error(json?.Note || json?.Information || 'API error / rate limit');
          localStorage.setItem(cacheKey, JSON.stringify({ ts: new Date().toISOString(), data: series }));
          return series;
        }

        function analyze(symbol, series) {
          const entries = Object.entries(series).sort((a,b) => new Date(a[0]) - new Date(b[0]));
          const dates = entries.map(([d]) => d);
          const closes = entries.map(([,v]) => Number(v['4. close']));

          const sma20 = calculateSMA(closes, 20);
          const sma50 = calculateSMA(closes, 50);
          const rsi14 = calculateRSI(closes, 14);
          const { macd, signal } = calculateMACD(closes, 12, 26, 9);

          const n = closes.length - 1;
          const todayClose = closes[n];
          const prevClose  = closes[n-1];
          const rsiNow = rsi14[n];
          const sma20Now = sma20[n];
          const sma50Now = sma50[n];
          const macdNow = macd[n];
          const macdPrev = macd[n-1];
          const sigNow = signal[n];
          const sigPrev = signal[n-1];

          const ret20 = n >= 20 ? (todayClose / closes[n-20] - 1) : null;
          const ret50 = n >= 50 ? (todayClose / closes[n-50] - 1) : null;

          // 52-week breakout proxy (use available history, up to 252 trading days)
          const lookback = Math.min(closes.length, 252);
          const window = closes.slice(closes.length - lookback);
          const rangeHigh = Math.max(...window);
          const rangeLow  = Math.min(...window);
          const isHighBreak = todayClose >= rangeHigh && rangeHigh !== -Infinity;
          const isLowBreak  = todayClose <= rangeLow && rangeLow !== Infinity;

          let score = 0; const notes = [];

          // Trend (SMA)
          if (sma20Now && sma50Now) {
            if (sma20Now > sma50Now) { score += 2; notes.push('SMA20 > SMA50 (uptrend)'); }
            if (todayClose > sma50Now) { score += 1; notes.push('Price above SMA50 (support)'); }
          }

          // Crossovers
          if (sma20[n-1] != null && sma50[n-1] != null) {
            const wasUp = sma20[n-1] > sma50[n-1];
            const isUp = sma20Now > sma50Now;
            if (!wasUp && isUp) { score += 2; notes.push('Bullish 20/50 crossover'); }
            if (wasUp && !isUp) { score -= 2; notes.push('Bearish 20/50 crossover'); }
          }

          // RSI
          if (rsiNow != null) {
            if (rsiNow > 70) { score -= 1; notes.push('RSI>70 (overbought)'); }
            else if (rsiNow < 30) { score -= 0.5; notes.push('RSI<30 (oversold — risky)'); }
            else { score += 0.5; notes.push('RSI neutral (30–70)'); }
          }

          // Momentum
          if (ret20 != null) { score += ret20 > 0 ? 1 : -1; notes.push((ret20>0?'+':'') + '20d momentum ' + pct(ret20)); }
          if (ret50 != null) { score += ret50 > 0 ? 0.5 : -0.5; }

          // MACD
          if (macdNow != null && sigNow != null) {
            if (macdNow > sigNow) { score += 1; notes.push('MACD above signal'); }
            else { score -= 0.5; notes.push('MACD below signal'); }
            if (macdPrev != null && sigPrev != null) {
              const prevUp = macdPrev > sigPrev;
              const nowUp = macdNow > sigNow;
              if (!prevUp && nowUp) { score += 1.5; notes.push('Bullish MACD crossover'); }
              if (prevUp && !nowUp) { score -= 1.5; notes.push('Bearish MACD crossover'); }
            }
          }

          // Breakouts
          if (isHighBreak) { score += 2; notes.push('Range-high breakout'); }
          if (isLowBreak)  { score -= 2; notes.push('Range-low breakdown'); }

          const dayChange = prevClose ? todayClose / prevClose - 1 : null;
          if (dayChange != null) notes.push('Today ' + (dayChange >= 0 ? 'up ' : 'down ') + pct(dayChange));

          const sentiment = score >= 3 ? 'BUY' : score <= -3 ? 'SELL/TRIM' : 'WATCH';

          return { symbol, date: dates[n], todayClose, rsi: rsiNow, sma20: sma20Now, sma50: sma50Now, macd: macdNow, macdSignal: sigNow, ret20, score, sentiment, notes };
        }

        async function run() {
          const list = tickers.split(/[ ,
	]+/).map(s => s.trim().toUpperCase()).filter(Boolean);
          if (list.length === 0) return;
          setIsLoading(true); setResults([]); setStatus('Fetching data…');
          const max = useMock ? list.length : Math.min(batchSize, list.length);
          const out = [];
          for (let i = 0; i < max; i++) {
            const sym = list[i];
            try {
              setStatus(`(${i+1}/${max}) ${sym}`);
              const series = await fetchSeries(sym);
              if (!series) throw new Error('No series returned');
              out.push(analyze(sym, series));
              if (!useMock && i < max - 1) await sleep(1500);
            } catch (e) {
              out.push({ symbol: sym, error: String(e.message || e), sentiment: 'ERROR' });
            }
          }
          out.sort((a,b) => (b.score ?? -Infinity) - (a.score ?? -Infinity));
          setResults(out); setIsLoading(false);
          setStatus(useMock ? 'Mock Mode complete' : `Done${list.length>max?` (fetched ${max} of ${list.length} due to batch size)`:''}`);
        }

        const buys  = useMemo(() => results.filter(r => r.sentiment === 'BUY'), [results]);
        const sells = useMemo(() => results.filter(r => r.sentiment === 'SELL/TRIM'), [results]);
        const watch = useMemo(() => results.filter(r => r.sentiment === 'WATCH'), [results]);

        return (
          <div className="min-h-screen">
            <header className="sticky top-0 z-10 backdrop-blur bg-white/70 border-b border-slate-200">
              <div className="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
                <div className="flex items-center gap-3">
                  <div className="h-10 w-10 rounded-2xl bg-slate-900 text-white grid place-items-center font-bold">SP</div>
                  <div>
                    <h1 className="text-xl font-semibold">Daily Stock Picks</h1>
                    <p className="text-xs text-slate-500">RSI · SMA · MACD · Breakouts — {today}</p>
                  </div>
                </div>
                <div className="hidden md:flex items-center gap-2 text-xs text-slate-500">
                  <span className="px-2 py-1 rounded-full bg-slate-100">Not investment advice</span>
                </div>
              </div>
            </header>

            <main className="max-w-6xl mx-auto px-4 py-6 grid gap-6">
              <section className="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                <div className="p-4 rounded-2xl shadow-sm bg-white border border-slate-200">
                  <label className="text-sm font-medium">Alpha Vantage API Key</label>
                  <input type="password" value={apiKey} onChange={(e)=>setApiKey(e.target.value)} placeholder="Paste key (leave empty for Mock Mode)" className="mt-2 w-full rounded-xl border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-300"/>
                  <div className="mt-2 text-xs text-slate-500">No key? The app switches to Mock Mode with demo data.</div>
                </div>
                <div className="p-4 rounded-2xl shadow-sm bg-white border border-slate-200">
                  <label className="text-sm font-medium">Tickers</label>
                  <textarea value={tickers} onChange={(e)=>setTickers(e.target.value)} className="mt-2 w-full rounded-xl border px-3 py-2 text-sm h-20 focus:outline-none focus:ring-2 focus:ring-slate-300" placeholder="Comma or space separated (e.g., AAPL, MSFT, NVDA)"/>
                  <div className="mt-2 flex items-center justify-between">
                    <div className="text-xs text-slate-500">Saved automatically</div>
                    <button onClick={()=>setTickers('AAPL,MSFT,NVDA,GOOGL,AMZN')} className="text-xs underline">Reset sample</button>
                  </div>
                </div>
                <div className="p-4 rounded-2xl shadow-sm bg-white border border-slate-200">
                  <label className="text-sm font-medium">Batch size (per run)</label>
                  <input type="number" min={1} max={25} value={batchSize} onChange={(e)=>setBatchSize(Number(e.target.value)||1)} className="mt-2 w-28 rounded-xl border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-300"/>
                  <div className="mt-2 text-xs text-slate-500">Free API tip: keep at 5–10 to avoid rate limits.</div>
                </div>
              </section>

              <section className="flex flex-wrap items-center gap-3">
                <button disabled={isLoading} onClick={run} className="px-4 py-2 rounded-2xl bg-slate-900 text-white disabled:opacity-60 shadow hover:shadow-md transition">{isLoading ? 'Analyzing…' : 'Refresh Today’s Picks'}</button>
                <span className="text-sm text-slate-600">{status}</span>
                <span className="ml-auto text-xs px-2 py-1 rounded-full border border-slate-300 bg-white">Mode: {useMock ? 'Mock (demo)' : 'Live (Alpha Vantage)'}</span>
              </section>

              <section className="grid gap-6 lg:grid-cols-3">
                <Column title="Top BUY Candidates" items={buys} emptyHint="Run analysis to see bullish setups." tone="buy" />
                <Column title="Top SELL / TRIM Candidates" items={sells} emptyHint="Nothing flashing red yet." tone="sell" />
                <Column title="Watchlist" items={watch} emptyHint="Neutral or mixed signals." tone="watch" />
              </section>

              {results.length > 0 && (
                <section className="rounded-2xl overflow-hidden border border-slate-200 shadow-sm bg-white">
                  <div className="px-4 py-3 border-b bg-slate-50">All Signals</div>
                  <div className="overflow-x-auto">
                    <table className="w-full text-sm">
                      <thead className="text-left bg-slate-50">
                        <tr>
                          <Th>Symbol</Th><Th>Date</Th><Th>Close</Th><Th>RSI14</Th><Th>SMA20</Th><Th>SMA50</Th><Th>MACD</Th><Th>Signal</Th><Th>20d Ret</Th><Th>Score</Th><Th>Signal</Th>
                        </tr>
                      </thead>
                      <tbody>
                        {results.map(r => (
                          <tr key={r.symbol} className="border-t">
                            <Td>{r.symbol}</Td>
                            <Td>{r.date || '—'}</Td>
                            <Td>{r.todayClose ? '$'+fmt.format(r.todayClose) : '—'}</Td>
                            <Td>{r.rsi ? fmt.format(r.rsi) : '—'}</Td>
                            <Td>{r.sma20 ? '$'+fmt.format(r.sma20) : '—'}</Td>
                            <Td>{r.sma50 ? '$'+fmt.format(r.sma50) : '—'}</Td>
                            <Td>{r.macd != null ? fmt.format(r.macd) : '—'}</Td>
                            <Td>{r.macdSignal != null ? fmt.format(r.macdSignal) : '—'}</Td>
                            <Td>{r.ret20 != null ? pct(r.ret20) : '—'}</Td>
                            <Td>{r.score != null ? fmt.format(r.score) : '—'}</Td>
                            <Td>
                              <span className={`px-2 py-1 rounded-full text-xs border ${r.sentiment==='BUY'?'bg-green-50 border-green-300':r.sentiment==='SELL/TRIM'?'bg-rose-50 border-rose-300':r.sentiment==='ERROR'?'bg-amber-50 border-amber-300':'bg-slate-50 border-slate-300'}`}>{r.sentiment}</span>
                            </Td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </section>
              )}

              <section className="text-xs text-slate-500 leading-relaxed">
                <p>Disclaimer: This tool is for educational purposes only and does not constitute financial, investment, or trading advice. Signals are derived from technical indicators and do not account for your objectives, risk tolerance, taxes, liquidity needs, or time horizon.</p>
              </section>
            </main>

            <footer className="py-8 text-center text-xs text-slate-400">© <span>{new Date().getFullYear()}</span> Daily Stock Picks — Educational Demo</footer>
          </div>
        );
      }

      function Column({ title, items, emptyHint, tone }) {
        return (
          <div className="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div className="px-4 py-3 border-b bg-slate-50 flex items-center justify-between">
              <h2 className="text-sm font-semibold">{title}</h2>
              <span className={`text-[10px] px-2 py-1 rounded-full border ${tone==='buy'?'bg-green-50 border-green-200':tone==='sell'?'bg-rose-50 border-rose-200':'bg-slate-50 border-slate-200'}`}>{items.length} items</span>
            </div>
            <div className="divide-y">
              {items.length === 0 && (<div className="p-4 text-sm text-slate-500">{emptyHint}</div>)}
              {items.map(r => (
                <div key={r.symbol} className="p-4">
                  <div className="flex items-baseline justify-between gap-4">
                    <div className="font-medium text-slate-900">{r.symbol}</div>
                    <div className="text-sm text-slate-600">${fmt.format(r.todayClose)}</div>
                  </div>
                  <div className="mt-1 text-xs text-slate-600">{r.date}</div>
                  <div className="mt-2 flex flex-wrap gap-2">
                    {r.notes.map((n, i) => (
                      <span key={i} className="text-[11px] px-2 py-1 rounded-full bg-slate-100 border border-slate-200">{n}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      }

      function Th({ children }) { return <th className="px-3 py-2 text-xs font-medium text-slate-600">{children}</th>; }
      function Td({ children }) { return <td className="px-3 py-2">{children}</td>; }

      const root = ReactDOM.createRoot(document.getElementById('root'));
      root.render(React.createElement(App));
    </script>
  </body>
</html>
